@page
@model Time_Bank_V1.Pages.Offers.CreateModel
@using Time_Bank_V1.Data.Entities
@{
    ViewData["Title"] = "Post a Service";
}

<div class="mb-4">
    <h2 class="mb-0"><i class="fa fa-plus-circle me-2 text-success"></i>Post a Service</h2>
    <p class="text-muted small">Share what you can offer, or let the community know what you need</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0">Service Details</h6>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <!-- Offer type -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
                        <div class="d-flex gap-3">
                            <div class="form-check form-check-inline">
                                <input asp-for="Input.OfferType" class="form-check-input" type="radio" value="Offer" id="typeOffer" checked />
                                <label class="form-check-label" for="typeOffer">
                                    <span class="badge bg-success me-1">Offering</span> I can provide this service
                                </label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input asp-for="Input.OfferType" class="form-check-input" type="radio" value="Request" id="typeRequest" />
                                <label class="form-check-label" for="typeRequest">
                                    <span class="badge bg-primary me-1">Requesting</span> I need this service
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                        <input asp-for="Input.Title" class="form-control" placeholder="e.g. Tax preparation help, Grocery run, Lawn mowing" />
                        <span asp-validation-for="Input.Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.CategoryId" class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                        <select asp-for="Input.CategoryId" class="form-select">
                            <option value="">Select a category...</option>
                            @foreach (var cat in Model.Categories.Where(c => c.ParentCategoryId == null))
                            {
                                <optgroup label="@cat.Name">
                                    @foreach (var sub in cat.SubCategories.Where(s => s.IsActive))
                                    {
                                        <option value="@sub.Id">@sub.Name</option>
                                    }
                                    <option value="@cat.Id">@cat.Name (General)</option>
                                </optgroup>
                            }
                        </select>
                        <span asp-validation-for="Input.CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="4"
                                  placeholder="Describe what you're offering or requesting. Include any relevant details, your experience, or special considerations..."></textarea>
                        <span asp-validation-for="Input.Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.EstimatedHours" class="form-label fw-semibold">Estimated Hours</label>
                            <input asp-for="Input.EstimatedHours" type="number" step="0.25" min="0.25" class="form-control" placeholder="e.g. 2.5" />
                            <div class="form-text">Approximate hours needed</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.LocationPreference" class="form-label fw-semibold">Location / Area</label>
                            <input asp-for="Input.LocationPreference" class="form-control" placeholder="e.g. Gainesville, NE area, Remote" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Keywords" class="form-label fw-semibold">Keywords <span class="text-muted">(comma-separated)</span></label>
                        <input asp-for="Input.Keywords" class="form-control" placeholder="e.g. bilingual, weekends, senior-friendly, remote" />
                        <div class="form-text">Keywords help members find your posting</div>
                    </div>

                    <div class="d-flex gap-3 justify-content-end">
                        <a asp-page="/Offers" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fa fa-paper-plane me-2"></i>Post Service
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
