@page "{id:int}"
@model Time_Bank_V1.Pages.Offers.DetailsModel
@using Time_Bank_V1.Data.Entities
@{
    ViewData["Title"] = Model.Offer?.Title ?? "Service Details";
    var offer = Model.Offer;
    var user = offer?.User;
    var typeColor = offer?.OfferType == OfferType.Offer ? "success" : "primary";
    var typeLabel = offer?.OfferType == OfferType.Offer ? "Offering" : "Requesting";
}

@if (offer == null)
{
    <div class="alert alert-warning">Service not found.</div>
    return;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Offers" class="text-success">Browse Services</a></li>
        <li class="breadcrumb-item active">@offer.Title</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header d-flex align-items-center gap-3">
                @if (!string.IsNullOrEmpty(user?.ProfilePicturePath))
                {
                    <img src="@user.ProfilePicturePath" class="rounded-circle" style="width:48px;height:48px;object-fit:cover;" alt="@user.Initials" />
                }
                else
                {
                    <div class="acc-avatar-lg">@(user?.Initials ?? "?")</div>
                }
                <div>
                    <h5 class="mb-0">@offer.Title</h5>
                    <small class="text-muted">
                        <span class="badge bg-@typeColor me-1">@typeLabel</span>
                        @offer.Category?.Name
                    </small>
                </div>
            </div>
            <div class="card-body">
                <p class="card-text">@offer.Description</p>

                <div class="row g-3 mt-2">
                    @if (offer.EstimatedHours.HasValue)
                    {
                        <div class="col-auto">
                            <span class="badge bg-light text-dark border p-2">
                                <i class="fa fa-clock me-1 text-success"></i>~@offer.EstimatedHours.Value.ToString("0.##") hours
                            </span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(offer.LocationPreference))
                    {
                        <div class="col-auto">
                            <span class="badge bg-light text-dark border p-2">
                                <i class="fa fa-location-dot me-1 text-success"></i>@offer.LocationPreference
                            </span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(offer.Keywords))
                    {
                        @foreach (var kw in offer.Keywords.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div class="col-auto">
                                <span class="badge bg-light text-dark border p-2">@kw.Trim()</span>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="card-footer bg-white d-flex gap-2 justify-content-end">
                @if (Model.IsOwner)
                {
                    <form method="post" asp-page-handler="Deactivate">
                        <input type="hidden" name="offerId" value="@offer.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Deactivate this offer?')">
                            <i class="fa fa-xmark me-1"></i>Deactivate
                        </button>
                    </form>
                }
                else if (Model.AlreadyMatched)
                {
                    <span class="badge bg-success p-2"><i class="fa fa-check me-1"></i>You're already matched</span>
                }
                else
                {
                    <form method="post" asp-page-handler="RequestMatch">
                        <input type="hidden" name="offerId" value="@offer.Id" />
                        <button type="submit" class="btn btn-@typeColor">
                            <i class="fa fa-handshake me-2"></i>
                            @(offer.OfferType == OfferType.Offer ? "Request This Service" : "Offer My Help")
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="fa fa-user me-2 text-success"></i>About the Member</h6>
            </div>
            <div class="card-body">
                @{
                    var vis = user?.PublicFieldVisibility?.Split(',') ?? Array.Empty<string>();
                }
                <h6>@(vis.Contains("Name") ? user?.FullName : "Anonymous Member")</h6>
                @if (vis.Contains("City") && !string.IsNullOrEmpty(user?.City))
                {
                    <p class="text-muted small mb-1"><i class="fa fa-location-dot me-1"></i>@user.City</p>
                }
                @if (vis.Contains("Bio") && !string.IsNullOrEmpty(user?.Bio))
                {
                    <p class="small mb-2">@user.Bio</p>
                }
                @if (vis.Contains("Availability") && (user?.Availabilities?.Any() ?? false))
                {
                    <p class="small text-muted mb-0"><i class="fa fa-calendar me-1"></i>
                        @string.Join(", ", user.Availabilities.Select(a => $"{a.DayOfWeek} {a.TimeSlot}").Distinct().Take(3))
                    </p>
                }
                @if (user?.ShowLicensure == true && !string.IsNullOrEmpty(user?.Licensure))
                {
                    <div class="mt-2"><span class="badge bg-info text-dark"><i class="fa fa-certificate me-1"></i>@user.Licensure</span></div>
                }
                <div class="mt-3">
                    <a asp-page="/Messages/Compose" asp-route-toUserId="@user?.Id" class="btn btn-sm btn-outline-success w-100">
                        <i class="fa fa-envelope me-1"></i>Send Anonymous Message
                    </a>
                </div>
            </div>
        </div>
        <div class="card shadow-sm mt-3">
            <div class="card-body text-muted small">
                <p class="mb-1"><strong>Posted:</strong> @offer.CreatedAt.ToString("MMMM d, yyyy")</p>
                <p class="mb-0"><strong>Status:</strong> @offer.Status</p>
            </div>
        </div>
    </div>
</div>
