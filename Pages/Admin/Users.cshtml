@page
@model Time_Bank_V1.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="fa fa-users me-2 text-warning"></i>Manage Users</h2>
    <a asp-page="/Admin/Index" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left me-1"></i>Admin Home</a>
</div>

<!-- Search -->
<form method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <input type="text" name="Search" value="@Model.Search" class="form-control" placeholder="Search by name or email..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-success"><i class="fa fa-search me-1"></i>Search</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover shadow-sm rounded">
        <thead class="table-light">
            <tr>
                <th>Member</th>
                <th>Type</th>
                <th class="text-end">Balance</th>
                <th class="text-center">Status</th>
                <th class="text-center">Monthly Grant</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Users)
            {
                <tr class="@(u.IsBalanceLocked ? "table-danger" : "")">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="acc-avatar-sm" style="width:32px;height:32px;font-size:0.75rem;">@u.Initials</div>
                            <div>
                                <div class="fw-semibold small">@u.FullName</div>
                                <small class="text-muted">@u.Email</small>
                            </div>
                        </div>
                    </td>
                    <td><span class="badge bg-@(u.AccountType == "Admin" ? "warning text-dark" : u.AccountType == "Organization" ? "primary" : "secondary")">@u.AccountType</span></td>
                    <td class="text-end fw-bold @(u.TimeBalance < 0 ? "text-danger" : "text-success")">
                        @u.TimeBalance.ToString("+0.##;-0.##;0")h
                    </td>
                    <td class="text-center">
                        @if (u.IsBalanceLocked)
                        {
                            <span class="badge bg-danger"><i class="fa fa-lock me-1"></i>Locked</span>
                        }
                        else if (u.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td class="text-center">
                        @if (u.IsEligibleForMonthlyGrant)
                        {
                            <span class="badge bg-info text-dark">@u.MonthlyGrantHours.ToString("0.##")h/mo</span>
                        }
                        else
                        {
                            <span class="text-muted small">—</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            <!-- Grant hours modal trigger -->
                            <button type="button" class="btn btn-xs btn-outline-success"
                                    data-bs-toggle="modal" data-bs-target="#grantModal"
                                    data-userid="@u.Id" data-username="@u.FullName">
                                <i class="fa fa-plus"></i> Hours
                            </button>
                            <!-- Monthly grant toggle -->
                            <form method="post" asp-page-handler="SetGrant" style="display:inline;">
                                <input type="hidden" name="userId" value="@u.Id" />
                                <input type="hidden" name="eligible" value="@(!u.IsEligibleForMonthlyGrant)" />
                                <input type="hidden" name="hours" value="@(u.MonthlyGrantHours > 0 ? u.MonthlyGrantHours : 5)" />
                                <button type="submit" class="btn btn-xs btn-outline-info" title="Toggle monthly grant">
                                    <i class="fa fa-calendar"></i>
                                </button>
                            </form>
                            <!-- Flag -->
                            <button type="button" class="btn btn-xs btn-outline-warning"
                                    data-bs-toggle="modal" data-bs-target="#flagModal"
                                    data-userid="@u.Id" data-username="@u.FullName">
                                <i class="fa fa-flag"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Grant Hours Modal -->
<div class="modal fade" id="grantModal" tabindex="-1" aria-labelledby="grantModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="GrantHours">
                <div class="modal-header">
                    <h5 class="modal-title" id="grantModalLabel">Grant Time Credits</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="grantUserId" name="userId" />
                    <p>Granting hours to: <strong id="grantUserName"></strong></p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hours to Grant</label>
                        <input type="number" name="hours" min="0.25" step="0.25" class="form-control" value="5" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reason</label>
                        <input type="text" name="reason" class="form-control" placeholder="e.g. Accessibility grant, Community bonus" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Grant Hours</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Flag User Modal -->
<div class="modal fade" id="flagModal" tabindex="-1" aria-labelledby="flagModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="FlagUser">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="flagModalLabel"><i class="fa fa-flag me-2"></i>Flag User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="flagUserId" name="userId" />
                    <p>Flagging: <strong id="flagUserName"></strong></p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reason for Flag</label>
                        <textarea name="reason" class="form-control" rows="3"
                                  placeholder="Describe the issue with this user's profile or content..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Flag for Review</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>.btn-xs { padding: 0.1rem 0.4rem; font-size: 0.75rem; }</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('grantModal').addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                document.getElementById('grantUserId').value = btn.dataset.userid;
                document.getElementById('grantUserName').textContent = btn.dataset.username;
            });
            document.getElementById('flagModal').addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                document.getElementById('flagUserId').value = btn.dataset.userid;
                document.getElementById('flagUserName').textContent = btn.dataset.username;
            });
        });
    </script>
}
