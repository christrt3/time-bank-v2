@page
@model Time_Bank_V1.Pages.IndexModel
@{
    ViewData["Title"] = "Welcome";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="text-center mb-4">
    <h1 class="display-6 fw-bold text-success"><i class="fa fa-clock me-2"></i>Alachua Community Collective</h1>
    <p class="lead text-muted">Exchange time, not money. Every hour you give is an hour you earn.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger text-center"><i class="fa fa-triangle-exclamation me-2"></i>@Model.ErrorMessage</div>
}

<div class="row g-4 justify-content-center">
    <!-- LOGIN -->
    <div class="col-md-5">
        <div class="card shadow h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fa fa-right-to-bracket me-2"></i>Sign In</h5>
            </div>
            <div class="card-body p-4">
                <form method="post" asp-page-handler="Login">
                    <div class="mb-3">
                        <label asp-for="LoginInput.Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                        <input asp-for="LoginInput.Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                        <span asp-validation-for="LoginInput.Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LoginInput.Password" class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                        <input asp-for="LoginInput.Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                        <span asp-validation-for="LoginInput.Password" class="text-danger small"></span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="LoginInput.RememberMe" class="form-check-input" />
                            <label asp-for="LoginInput.RememberMe" class="form-check-label small">Remember me</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100 py-2">
                        <i class="fa fa-right-to-bracket me-2"></i>Sign In
                    </button>
                </form>
                <hr />
                <p class="text-muted small text-center mb-0">
                    <strong>Admin demo:</strong> admin@acc.org / Admin@12345!
                </p>
            </div>
        </div>
    </div>

    <!-- REGISTER -->
    <div class="col-md-7">
        <div class="card shadow h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="fa fa-user-plus me-2"></i>Create Account</h5>
            </div>
            <div class="card-body p-4">
                <form method="post" asp-page-handler="Register">
                    <h6 class="text-uppercase text-muted fw-bold small mb-3 border-bottom pb-2">Basic Information</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.FirstName" class="form-label fw-semibold small">First Name <span class="text-danger">*</span></label>
                            <input asp-for="RegisterInput.FirstName" class="form-control" placeholder="First" />
                            <span asp-validation-for="RegisterInput.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.LastName" class="form-label fw-semibold small">Last Name <span class="text-danger">*</span></label>
                            <input asp-for="RegisterInput.LastName" class="form-control" placeholder="Last" />
                            <span asp-validation-for="RegisterInput.LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.Email" class="form-label fw-semibold small">Email <span class="text-danger">*</span></label>
                            <input asp-for="RegisterInput.Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                            <span asp-validation-for="RegisterInput.Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.Phone" class="form-label fw-semibold small">Phone</label>
                            <input asp-for="RegisterInput.Phone" class="form-control" placeholder="(352) 555-0100" />
                        </div>
                    </div>

                    <h6 class="text-uppercase text-muted fw-bold small mb-3 border-bottom pb-2">Account Setup</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.AccountType" class="form-label fw-semibold small">Account Type <span class="text-danger">*</span></label>
                            <select asp-for="RegisterInput.AccountType" class="form-select">
                                <option value="Member">Individual Member</option>
                                <option value="Organization">Organization</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.City" class="form-label fw-semibold small">City</label>
                            <input asp-for="RegisterInput.City" class="form-control" placeholder="Gainesville" />
                        </div>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.Password" class="form-label fw-semibold small">Password <span class="text-danger">*</span></label>
                            <input asp-for="RegisterInput.Password" type="password" class="form-control" placeholder="Min. 8 chars, 1 uppercase, 1 number" autocomplete="new-password" />
                            <span asp-validation-for="RegisterInput.Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegisterInput.ConfirmPassword" class="form-label fw-semibold small">Confirm Password <span class="text-danger">*</span></label>
                            <input asp-for="RegisterInput.ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" autocomplete="new-password" />
                            <span asp-validation-for="RegisterInput.ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <h6 class="text-uppercase text-muted fw-bold small mb-3 border-bottom pb-2">Additional Options</h6>
                    <div class="mb-2 form-check">
                        <input asp-for="RegisterInput.IsGuardian" class="form-check-input" />
                        <label asp-for="RegisterInput.IsGuardian" class="form-check-label small">This is a guardian account managing an account for a minor (13+)</label>
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="RegisterInput.AgreeToTerms" class="form-check-input" />
                        <label asp-for="RegisterInput.AgreeToTerms" class="form-check-label small">I agree to the <a href="/Privacy" class="text-success">community guidelines &amp; privacy policy</a> <span class="text-danger">*</span></label>
                        <span asp-validation-for="RegisterInput.AgreeToTerms" class="text-danger small d-block"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2">
                        <i class="fa fa-user-plus me-2"></i>Create Account
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
